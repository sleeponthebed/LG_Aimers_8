RESPONSE_MARKER = "[|assistant|]"
END_TURN_MARKER = "[|endofturn|]"
USER_MARKER = "[|user|]"
SYSTEM_MARKER = "[|system|]"

def _token_len(s: str, max_len: int):
    return len(tokenizer(s, truncation=True, max_length=max_len, padding=False)["input_ids"])

def tokenize_and_mask_assistant_only(example, max_len=1024):
    text = example["text"]

    tok = tokenizer(
        text,
        truncation=True,
        max_length=max_len,
        padding=False,
    )
    input_ids = tok["input_ids"]
    labels = [-100] * len(input_ids)

    # assistant 구간(텍스트 기준) 모두 찾아서 그 구간만 labels 활성화
    start = 0
    while True:
        a_idx = text.find(RESPONSE_MARKER, start)
        if a_idx == -1:
            break

        # assistant marker 직후부터
        a_content_start = a_idx + len(RESPONSE_MARKER)

        # 해당 assistant 턴의 끝: endofturn 또는 다음 user/system marker 전
        end_candidates = []
        e1 = text.find(END_TURN_MARKER, a_content_start)
        if e1 != -1:
            end_candidates.append(e1)
        u1 = text.find(USER_MARKER, a_content_start)
        if u1 != -1:
            end_candidates.append(u1)
        s1 = text.find(SYSTEM_MARKER, a_content_start)
        if s1 != -1:
            end_candidates.append(s1)

        if end_candidates:
            a_content_end = min(end_candidates)
        else:
            a_content_end = len(text)

        # 토큰 인덱스 구간 계산: prefix 길이로 위치 맞추기
        prefix = text[:a_content_start]
        upto_end = text[:a_content_end]

        st = _token_len(prefix, max_len)
        ed = _token_len(upto_end, max_len)

        # 범위 보호
        st = min(st, len(labels))
        ed = min(ed, len(labels))

        for i in range(st, ed):
            labels[i] = input_ids[i]

        start = a_content_end

    tok["labels"] = labels
    return tok

