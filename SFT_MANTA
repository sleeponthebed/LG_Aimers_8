def convert_qa_to_text(question: str, answer: str):
    chat = [
        {"role": "user", "content": f"{question}"},
        {"role": "assistant", "content": f"{answer}"},
    ]
    return {"text": tokenizer.apply_chat_template(chat, tokenize=False)}


def normalize_role(role: str) -> str:
    r = role.lower().strip()
    if r in ["user", "human", "client", "questioner"]:
        return "user"
    if r in ["assistant", "bot", "agent", "answerer"]:
        return "assistant"
    # 혹시 system이 있으면 system으로 유지
    if r in ["system"]:
        return "system"
    # 그 외는 user로 처리(보수적)
    return "user"

def convert_manta_to_text(example):
    conv = example["conversations"]  # list of {role, content}
    chat = []
    for turn in conv:
        role = normalize_role(turn["role"])
        content = turn["content"]
        if content is None:
            continue
        content = str(content).strip()
        if not content:
            continue
        chat.append({"role": role, "content": content})

    # 마지막이 assistant가 아니면 학습 품질이 저하 가능성 존재, 제거
    # -> 마지막 assistant 응답이 있어야 SFT 유의미
    if len(chat) < 2 or chat[-1]["role"] != "assistant":
        return {"text": None}

    return {"text": tokenizer.apply_chat_template(chat, tokenize=False)}


