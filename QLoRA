def format_example(example):
    text = tokenizer.apply_chat_template(
        example["conversations"],
        tokenize=False,
        add_generation_prompt=False,
    )
    return {"text": text}

train_text = train_raw.map(
    format_example,
    remove_columns=train_raw.column_names,
)

val_text = val_raw.map(
    format_example,
    remove_columns=val_raw.column_names,
)


MAX_LEN = 2048

def tokenize_fn(example):
    tok = tokenizer(
        example["text"],
        truncation=True,
        max_length=MAX_LEN,
        padding=False,
    )
    tok["labels"] = tok["input_ids"].copy()
    return tok


train_dataset = train_text.map(
    tokenize_fn,
    remove_columns=train_text.column_names,
)

val_dataset = val_text.map(
    tokenize_fn,
    remove_columns=val_text.column_names,
)


def has_supervision(ex):
    return any(l != -100 for l in ex["labels"])

train_dataset = train_dataset.filter(has_supervision)
val_dataset   = val_dataset.filter(has_supervision)



import torch

class DataCollatorForCausalLM_Safe:
    def __init__(self, tokenizer):
        self.tokenizer = tokenizer
        if tokenizer.pad_token is None:
            tokenizer.pad_token = tokenizer.eos_token
        self.pad_token_id = tokenizer.pad_token_id

    def __call__(self, features):
        # labels를 먼저 분리
        labels = [f.pop("labels") for f in features]

        # input_ids / attention_mask만 tokenizer.pad로 처리
        batch = self.tokenizer.pad(
            features,
            padding=True,
            return_tensors="pt",
        )

        # labels를 직접 padding (-100)
        max_len = batch["input_ids"].size(1)
        padded_labels = torch.full(
            (len(labels), max_len),
            fill_value=-100,
            dtype=torch.long,
        )

        for i, lab in enumerate(labels):
            lab = torch.tensor(lab, dtype=torch.long)
            padded_labels[i, : lab.size(0)] = lab

        batch["labels"] = padded_labels
        return batch


from transformers import TrainingArguments, Trainer

data_collator = DataCollatorForCausalLM_Safe(tokenizer)


training_args = TrainingArguments(
    output_dir="./qlora_out",

    per_device_train_batch_size=2,
    per_device_eval_batch_size=2,
    gradient_accumulation_steps=8,

    learning_rate=2e-4,
    num_train_epochs=1,   # 2 이상은 너무 시간이 오래걸려 일단 1로 설정

    bf16=True,

    logging_steps=20,

    # validation loss 핵심
    eval_strategy="steps",
    eval_steps=200,

    save_strategy="steps",
    save_steps=200,

    load_best_model_at_end=True,
    metric_for_best_model="eval_loss",
    greater_is_better=False,

    optim="paged_adamw_8bit",
    report_to="none",
)


trainer = Trainer(
    model=model,
    args=training_args,
    train_dataset=train_dataset,
    eval_dataset=val_dataset,
    data_collator=data_collator,
)

trainer.train()


