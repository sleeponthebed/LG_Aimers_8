import os
import torch
from transformers import AutoTokenizer, AutoModelForCausalLM
from peft import PeftModel

BASE_DIR = "/content/drive/MyDrive/sft_models/exaone_sft_v3"        # 베이스 모델
ADAPTER_DIR = "/content/drive/MyDrive/QLoRA_Adapters/sft_qlora_MANTA_1M"  # 어댑터
OUT_DIR = "/content/drive/MyDrive/sft_models/exaone_merged_sft_qlora" # 출력

os.makedirs(OUT_DIR, exist_ok=True)

# 1) tokenizer는 보통 base에서 읽고, OUT_DIR에 저장
tokenizer = AutoTokenizer.from_pretrained(BASE_DIR, use_fast=True, trust_remote_code=True)

# pad_token 안전 처리 (없으면 eos로)
if tokenizer.pad_token is None:
    tokenizer.pad_token = tokenizer.eos_token

# 2) 베이스 모델을 fp16/bf16로 로드 (fp16 권장)
dtype = torch.float16
base = AutoModelForCausalLM.from_pretrained(
    BASE_DIR,
    torch_dtype=dtype,
    device_map="auto",
    trust_remote_code=True,
)

# 3) LoRA 어댑터를 붙임
peft_model = PeftModel.from_pretrained(base, ADAPTER_DIR)

# 4) merge + LoRA 레이어 제거(= 순수 모델로 만듦)
merged = peft_model.merge_and_unload()

# 5) config / 토큰 관련 세팅
merged.config.use_cache = True
merged.config.pad_token_id = tokenizer.pad_token_id

# 6) 저장 (safetensors로)
merged.save_pretrained(OUT_DIR, safe_serialization=True)
tokenizer.save_pretrained(OUT_DIR)

print("Merged model saved to:", OUT_DIR)
